# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.python-version

# Virtual environments
.venv/
worktrees/

# Agent prompt files (machine-specific)
CLAUDE.md
AGENTS.md

# Experimental artifacts (per-run, never committed)
dev/
results.tsv
run.log
verify.log
omniperf.log
correctness.log
learning.md
ideas.md
compiler_proposals.md
*.log

# Caches
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Analysis output (regenerated by analysis.py)
report.md
progress.png

# Profiler traces and dumps
traces/
prof/
*.gcn
*.ll

# Per-experiment runs (rocprofv3 stats CSVs, e2e JSON)
runs/

# Workspace (runtime artifacts: HALT.flag, learning.md, ideas-*.md, logs/, etc.)
workspace/

# Sandbox (sandbox.py defaults to ~/.cache/... but ignore at repo root in case
# someone overrides AUTOKERNEL_SANDBOX to a relative path)
sandbox/

# Editor / IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
